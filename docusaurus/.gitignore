# Dependencies
/node_modules

# Production
/build

# Docusaurus build artifacts
.docusaurus/*

# But keep the embeddings cache for CI efficiency
!.docusaurus/embeddings.json

# Node modules and other standard ignores
node_modules/
build/
.env.local

# Generated files
.cache-loader

# Misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Yarn 4 (berry) install cache — never commit, regenerated by `yarn install`.
# Keep .yarnrc.yml + .yarn/releases (if present) committed; everything else is ephemeral.
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
